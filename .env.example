# Datadog API Credentials
# Get your API key: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=your-api-key-here

# Get your Application key: https://app.datadoghq.com/organization-settings/application-keys
DD_APP_KEY=your-app-key-here

# Datadog Site (use short code)
# Options: us1, us3, us5, eu, ap1, gov
# Default: us5
DD_SITE=us5

# Optional: Maximum results per query (default: 50)
# DDMCP_MAX_RESULTS=50
